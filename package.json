{
  "name": "oc-crm-engine",
  "version": "1.0.0",
  "description": "Event-driven CRM automation engine for OrderChop restaurant SaaS platform",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "smoke-test": "tsx src/scripts/smoke-test.ts"
  },
  "keywords": [
    "crm",
    "automation",
    "orderchop",
    "kafka",
    "fastify"
  ],
  "author": "OrderChop",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "axios": "^1.7.9",
    "bullmq": "^5.34.8",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "jose": "^6.0.8",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.9.5",
    "nanoid": "^5.0.9",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
