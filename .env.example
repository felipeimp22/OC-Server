# ===========================================================
# oc-crm-engine — Environment Variables
# ===========================================================
# Copy this file to .env and fill in the values.
# Variables marked [SHARED] must match the OrderChop Next.js app.

# -----------------------------------------------------------
# Database — SAME MongoDB instance as OrderChop [SHARED]
# -----------------------------------------------------------
# Use the same connection string as NEXT_DATABASE_URL in oc-restaurant-manager
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/orderchop?retryWrites=true&w=majority

# -----------------------------------------------------------
# Kafka — Message Broker
# -----------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=oc-crm-engine
KAFKA_CONSUMER_GROUP=crm-engine-group

# -----------------------------------------------------------
# Redis — BullMQ Queue Backend
# -----------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------
# Auth — Shared secret with OrderChop NextAuth [SHARED]
# -----------------------------------------------------------
# Must be the same AUTH_SECRET used by oc-restaurant-manager
AUTH_SECRET=generate-with-openssl-rand-base64-32

# -----------------------------------------------------------
# Email Provider [SHARED]
# -----------------------------------------------------------
# Same Mailgun credentials as NEXT_EMAIL_* in oc-restaurant-manager
EMAIL_PROVIDER=mailgun
EMAIL_DOMAIN=go.orderchop.co
EMAIL_API_KEY=your-mailgun-api-key
EMAIL_FROM_NAME=OrderChop
EMAIL_FROM_ADDRESS=noreply@go.orderchop.co

# -----------------------------------------------------------
# SMS Provider (new — not in OrderChop yet)
# -----------------------------------------------------------
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# -----------------------------------------------------------
# Meta Conversions API (optional)
# -----------------------------------------------------------
META_PIXEL_ID=
META_ACCESS_TOKEN=

# -----------------------------------------------------------
# Server
# -----------------------------------------------------------
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
